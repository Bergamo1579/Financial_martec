{
  "name": "financial-martec",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "npx turbo@2.0.14 run dev --parallel",
    "build": "npx turbo@2.0.14 run build",
    "lint": "npx turbo@2.0.14 run lint",
    "typecheck": "npx turbo@2.0.14 run typecheck",
    "test": "npx turbo@2.0.14 run test",
    "db:generate": "npx pnpm@9.12.3 --filter @financial-martec/api prisma generate",
    "db:migrate": "npx pnpm@9.12.3 --filter @financial-martec/api prisma migrate dev",
    "db:deploy": "npx pnpm@9.12.3 --filter @financial-martec/api prisma migrate deploy",
    "db:seed": "npx pnpm@9.12.3 --filter @financial-martec/api prisma db seed"
  },
  "devDependencies": {
    "turbo": "2.0.14"
  }
}
