{
  "name": "@financial-martec/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch --entryFile apps/api/src/main --sourceRoot .",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "jest --runInBand",
    "test:integration:preflight": "tsx test/integration/preflight.ts",
    "test:integration": "jest --config jest.integration.config.ts --runInBand",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@financial-martec/contracts": "workspace:*",
    "@nestjs/common": "11.0.6",
    "@nestjs/config": "4.0.0",
    "@nestjs/core": "11.0.6",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.0.6",
    "@nestjs/swagger": "11.0.3",
    "@nestjs/throttler": "6.4.0",
    "@prisma/client": "5.22.0",
    "argon2": "0.41.1",
    "bullmq": "5.34.10",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "nestjs-pino": "4.3.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "pino-pretty": "13.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "uuid": "11.0.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "9.13.0",
    "@nestjs/cli": "11.0.5",
    "@nestjs/schematics": "11.0.1",
    "@nestjs/testing": "11.0.6",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.8.6",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "eslint": "9.13.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "globals": "15.11.0",
    "jest": "29.7.0",
    "prettier": "3.3.3",
    "prisma": "5.22.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.10",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "typescript-eslint": "8.10.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
