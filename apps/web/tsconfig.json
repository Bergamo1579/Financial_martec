{
  "extends": "../../packages/config/tsconfig/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@financial-martec/contracts": [
        "../../packages/contracts/src"
      ],
      "@financial-martec/contracts/*": [
        "../../packages/contracts/src/*"
      ],
      "@financial-martec/ui": [
        "../../packages/ui/src"
      ],
      "@/*": [
        "./*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "middleware.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "next-build-artifacts/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next-app",
    "next-build-artifacts"
  ]
}
